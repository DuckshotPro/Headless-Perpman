{
  "mcpServers": {
    "example-github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "your-github-token-here"
      }
    },
    "example-database": {
      "type": "sse",
      "url": "http://localhost:3001/sse"
    }
  },
  "bridge": {
    "port": 54319,
    "autoConnect": true
  }
}