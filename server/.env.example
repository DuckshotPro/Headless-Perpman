# Perplexity API key — get from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion integration token — get from https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: default Notion parent page ID to save queries under
# Get this from the page URL: notion.so/workspace/Page-Title-{THIS_PART}
# NOTION_DEFAULT_PAGE_ID=

# Optional: Notion database ID to save queries as rows
# NOTION_DEFAULT_DATABASE_ID=

# Port for the REST server (default: 3001)
# SERVER_PORT=3001
